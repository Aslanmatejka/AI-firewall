<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Neon Strike — aggressive cyber palette -->
    <SolidColorBrush x:Key="BgPrimaryBrush" Color="#030305"/>
    <SolidColorBrush x:Key="BgSecondaryBrush" Color="#08080E"/>
    <SolidColorBrush x:Key="BgElevatedBrush" Color="#0F0F18"/>
    <SolidColorBrush x:Key="BgHoverBrush" Color="#161622"/>
    <SolidColorBrush x:Key="BgActiveBrush" Color="#1E1E2E"/>
    <SolidColorBrush x:Key="RowAltBrush" Color="#06060A"/>

    <!-- Borders & neon glow -->
    <SolidColorBrush x:Key="BorderBrush" Color="#2A2A40"/>
    <SolidColorBrush x:Key="BorderSubtleBrush" Color="#141420"/>
    <SolidColorBrush x:Key="GlowIndigoBrush" Color="#6600F5FF"/>
    <SolidColorBrush x:Key="GlowVioletBrush" Color="#66FF006E"/>
    <SolidColorBrush x:Key="GlowCyanBrush" Color="#887B2FFF"/>

    <!-- Text — high contrast -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A8A8C0"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="#686880"/>

    <!-- Brand gradient — magenta → purple → electric cyan -->
    <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF006E" Offset="0"/>
        <GradientStop Color="#7B2FFF" Offset="0.45"/>
        <GradientStop Color="#00F5FF" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="SidebarGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#0A0A14" Offset="0"/>
        <GradientStop Color="#030305" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="HeaderGlow" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#50FF006E" Offset="0"/>
        <GradientStop Color="#4000F5FF" Offset="0.5"/>
        <GradientStop Color="#00000000" Offset="1"/>
    </LinearGradientBrush>

    <SolidColorBrush x:Key="AccentBrush" Color="#00F5FF"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#00D4E0"/>
    <SolidColorBrush x:Key="AccentSubtleBrush" Color="#0A2030"/>

    <!-- Stat card accents -->
    <SolidColorBrush x:Key="StatCyanBrush" Color="#00F5FF"/>
    <SolidColorBrush x:Key="StatCyanBgBrush" Color="#001820"/>
    <SolidColorBrush x:Key="StatVioletBrush" Color="#BF00FF"/>
    <SolidColorBrush x:Key="StatVioletBgBrush" Color="#180028"/>
    <SolidColorBrush x:Key="StatRoseBrush" Color="#FF2070"/>
    <SolidColorBrush x:Key="StatRoseBgBrush" Color="#280010"/>
    <SolidColorBrush x:Key="StatEmeraldBrush" Color="#00FF88"/>
    <SolidColorBrush x:Key="StatEmeraldBgBrush" Color="#002818"/>

    <!-- Semantic -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#00FF88"/>
    <SolidColorBrush x:Key="SuccessSubtleBrush" Color="#002818"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#FFEA00"/>
    <SolidColorBrush x:Key="WarningSubtleBrush" Color="#282000"/>
    <SolidColorBrush x:Key="DangerBrush" Color="#FF0040"/>
    <SolidColorBrush x:Key="DangerSubtleBrush" Color="#280008"/>
    <SolidColorBrush x:Key="PurpleBrush" Color="#BF00FF"/>

</ResourceDictionary>
