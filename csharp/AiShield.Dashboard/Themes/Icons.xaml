<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <FontFamily x:Key="IconFont">Segoe MDL2 Assets</FontFamily>

    <sys:String x:Key="IconShield">&#xEA18;</sys:String>
    <sys:String x:Key="IconHome">&#xE80F;</sys:String>
    <sys:String x:Key="IconDashboard">&#xE9D2;</sys:String>
    <sys:String x:Key="IconDocs">&#xE736;</sys:String>
    <sys:String x:Key="IconRobot">&#xE99A;</sys:String>
    <sys:String x:Key="IconGlobe">&#xE774;</sys:String>
    <sys:String x:Key="IconFolder">&#xE8B7;</sys:String>
    <sys:String x:Key="IconList">&#xE8FD;</sys:String>
    <sys:String x:Key="IconSettings">&#xE713;</sys:String>
    <sys:String x:Key="IconView">&#xE7B3;</sys:String>
    <sys:String x:Key="IconNetwork">&#xE968;</sys:String>
    <sys:String x:Key="IconLock">&#xE72E;</sys:String>
    <sys:String x:Key="IconBlock">&#xE711;</sys:String>
    <sys:String x:Key="IconSearch">&#xE721;</sys:String>
    <sys:String x:Key="IconPackage">&#xE719;</sys:String>
    <sys:String x:Key="IconLightning">&#xE945;</sys:String>
    <sys:String x:Key="IconCheck">&#xE73E;</sys:String>
    <sys:String x:Key="IconRefresh">&#xE72C;</sys:String>
    <sys:String x:Key="IconWarning">&#xE7BA;</sys:String>

    <Style x:Key="IconGlyph" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource IconFont}"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>
    <Style x:Key="IconXs" TargetType="TextBlock" BasedOn="{StaticResource IconGlyph}">
        <Setter Property="FontSize" Value="12"/>
    </Style>
    <Style x:Key="IconSm" TargetType="TextBlock" BasedOn="{StaticResource IconGlyph}">
        <Setter Property="FontSize" Value="14"/>
    </Style>
    <Style x:Key="IconMd" TargetType="TextBlock" BasedOn="{StaticResource IconGlyph}">
        <Setter Property="FontSize" Value="18"/>
    </Style>
    <Style x:Key="IconLg" TargetType="TextBlock" BasedOn="{StaticResource IconGlyph}">
        <Setter Property="FontSize" Value="22"/>
    </Style>
    <Style x:Key="IconXl" TargetType="TextBlock" BasedOn="{StaticResource IconGlyph}">
        <Setter Property="FontSize" Value="40"/>
    </Style>

</ResourceDictionary>
