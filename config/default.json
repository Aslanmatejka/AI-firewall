{
  "version": 1,
  "global_policy": "ask",
  "fail_closed": false,
  "protected_folders": [
    { "name": "Documents", "path": "%USERPROFILE%\\Documents", "policy": "ask" },
    { "name": "Photos", "path": "%USERPROFILE%\\Pictures", "policy": "ask" },
    { "name": "Passwords", "path": "%USERPROFILE%\\Documents\\Passwords", "policy": "block" },
    { "name": "Projects", "path": "%USERPROFILE%\\Projects", "policy": "ask" },
    { "name": "Financial", "path": "%USERPROFILE%\\Documents\\Financial", "policy": "block" }
  ],
  "ai_domains": [
    "openai.com",
    "api.openai.com",
    "chatgpt.com",
    "anthropic.com",
    "api.anthropic.com",
    "claude.ai",
    "gemini.google.com",
    "generativelanguage.googleapis.com",
    "copilot.microsoft.com",
    "api.cohere.ai",
    "huggingface.co",
    "replicate.com",
    "together.ai",
    "mistral.ai",
    "perplexity.ai",
    "ollama.com"
  ],
  "ai_process_signatures": [
    { "name": "ChatGPT", "patterns": ["chatgpt", "openai"] },
    { "name": "Ollama", "patterns": ["ollama"] },
    { "name": "LM Studio", "patterns": ["lm studio", "lmstudio"] },
    { "name": "Jan", "patterns": ["jan.exe", "jan-ai"] },
    { "name": "Claude", "patterns": ["claude", "anthropic"] },
    { "name": "Copilot", "patterns": ["copilot"] },
    { "name": "Cursor", "patterns": ["cursor.exe"] },
    { "name": "Continue", "patterns": ["continue"] },
    { "name": "Tabnine", "patterns": ["tabnine"] },
    { "name": "Codeium", "patterns": ["codeium"] },
    { "name": "LocalAI", "patterns": ["localai"] },
    { "name": "GPT4All", "patterns": ["gpt4all"] },
    { "name": "KoboldCpp", "patterns": ["koboldcpp"] },
    { "name": "Text Generation WebUI", "patterns": ["oobabooga", "text-generation"] }
  ],
  "ai_extension_patterns": [
    "chatgpt", "claude", "copilot", "merlin", "monica", "grammarly-go",
    "perplexity", "harpa", "sider", "maxai", "usechatgpt"
  ],
  "model_file_extensions": [".gguf", ".safetensors", ".bin", ".onnx", ".pt", ".pth", ".mlc"],
  "gpu_threshold_mb": 512,
  "network_policy": "ask",
  "clipboard_policy": "ask",
  "screenshot_policy": "block",
  "microphone_policy": "ask",
  "camera_policy": "ask",
  "encrypt_db_at_rest": true,
  "named_pipe_enabled": true,
  "wfp_enabled": true,
  "minifilter_enabled": true,
  "ml_heuristics_enabled": true,
  "ml_heuristic_threshold": 65,
  "enterprise_policy_url": "",
  "enterprise_sync_seconds": 300,
  "approval_ui": "dashboard",
  "approval_timeout_seconds": 120,
  "device_deny_cooldown_seconds": 3600,
  "monitor_interval_seconds": 2,
  "dashboard_host": "127.0.0.1",
  "dashboard_port": 9470,
  "allow_simulate_approval": false
}
